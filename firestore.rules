rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || hasRole('admin');
    }

    // Restaurants (publicly readable, admin writeable)
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if hasRole('admin');
      
      match /tables/{tableId} {
        allow read: if isAuthenticated();
        allow write: if hasRole('staff') || hasRole('admin');
      }
      
      match /menus/{menuId} {
        allow read: if true;
        allow write: if hasRole('admin');
      }
    }

    // Queues
    match /queues/{queueId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || hasRole('staff') || hasRole('admin'));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || hasRole('staff') || hasRole('admin'));
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || hasRole('staff') || hasRole('admin'));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || hasRole('staff') || hasRole('admin'));
    }
  }
}
